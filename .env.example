# Telegram Bot Token (required)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed user IDs (comma-separated, required)
ALLOWED_USERS=123456789,987654321

# Tmux session name (optional, defaults to "ccbot")
TMUX_SESSION_NAME=ccbot

# Claude command to run in new windows (optional, defaults to "claude")
CLAUDE_COMMAND=claude

# Monitor polling interval in seconds (optional, defaults to 2.0)
MONITOR_POLL_INTERVAL=2.0

# Inbound Telegram media limits (optional)
CCBOT_MAX_AUDIO_BYTES=52428800
CCBOT_MAX_VIDEO_BYTES=104857600
# Remote Telegram Bot API getFile/download limit; set to 0 only when using a local Bot API server with higher/no download limit.
CCBOT_MAX_TELEGRAM_DOWNLOAD_BYTES=20971520

# Telegram long-polling reliability (optional)
CCBOT_TELEGRAM_POOL_TIMEOUT=10.0
CCBOT_TELEGRAM_GET_UPDATES_POOL_SIZE=4
CCBOT_TELEGRAM_GET_UPDATES_POOL_TIMEOUT=10.0
CCBOT_TELEGRAM_GET_UPDATES_CONNECT_TIMEOUT=10.0
CCBOT_TELEGRAM_GET_UPDATES_READ_TIMEOUT=30.0
CCBOT_TELEGRAM_GET_UPDATES_WRITE_TIMEOUT=10.0
CCBOT_TELEGRAM_POLL_TIMEOUT=10
CCBOT_TELEGRAM_POLL_HEALTH_ENABLED=true
CCBOT_TELEGRAM_POLL_HEALTH_INTERVAL=60.0
CCBOT_TELEGRAM_POLL_STALE_SECONDS=180.0
CCBOT_TELEGRAM_POLL_PENDING_THRESHOLD=1
CCBOT_TELEGRAM_POLL_WATCHDOG_EXIT_CODE=75
